# Gemini API Key for general text/image generation
GEMINI_API_KEY=

# API Key for Live/Veo features (if different)
API_KEY=

# Razorpay Configuration
# Get these from your Razorpay Dashboard -> Settings -> API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email Configuration (for Welcome Emails)
# Use a Gmail account and generate an App Password
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
